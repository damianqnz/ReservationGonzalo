generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  name           String?
  email          String         @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  role           Role           @default(GUEST)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  accounts           Account[]
  notifications      Notification[]
  properties         Property[]
  sessions           Session[]
  pushSubscriptions  PushSubscription[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Property {
  id                 String             @id @default(cuid())
  ownerId            String
  title              String
  slug               String             @unique
  description        String
  type               PropertyType       @default(APARTMENT)
  status             PropertyStatus     @default(DRAFT)
  address            String
  city               String
  country            String             @default("PT")
  latitude           Float?
  longitude          Float?
  zipCode            String?
  maxGuests          Int                @default(1)
  bedrooms           Int                @default(1)
  bathrooms          Int                @default(1)
  beds               Int                @default(1)
  area               Float?
  pricePerNight      Float
  cleaningFee        Float              @default(0)
  securityDeposit    Float              @default(0)
  currency           String             @default("EUR")
  checkInTime        String             @default("15:00")
  checkOutTime       String             @default("11:00")
  minNights          Int                @default(1)
  maxNights          Int                @default(365)
  cancellationPolicy CancellationPolicy @default(FLEXIBLE)
  hasRooms           Boolean            @default(false)
  bedsConfig         String?            @db.Text
  bathroomType       String?
  services           String?            @db.Text
  rooms              Room[]
  // Arrival & Access
  arrivalType       String?   // "autonomous" | "guided"
  accessInfo        String?   @db.Text
  interactionInfo   String?   @db.Text
  additionalInfo    String?   @db.Text

  // Space details
  floors            Int?
  hasElevator       Boolean   @default(false)
  towelsIncluded    Boolean   @default(false)
  petsAllowed       Boolean   @default(false)
  childrenAllowed   Boolean   @default(true)
  smokingAllowed    Boolean   @default(false)

  // House rules
  extraServices     String?   @db.Text
  parkingInfo       String?   @db.Text
  cancellationDays  Int?      @default(0)
  houseRules        String?   @db.Text

  // Host
  licenseNumber     String?
  hostDescription   String?   @db.Text
  spaceDescription  String?   @db.Text
  // Access data
  accessCode         String?
  wifiName           String?
  wifiPassword       String?
  floor              String?
  accessInstructions String? @db.Text
  contactPhone       String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  blockedDates       BlockedDate[]
  bookings           Booking[]
  owner              User               @relation(fields: [ownerId], references: [id])
  amenities          PropertyAmenity[]
  images             PropertyImage[]
  reviews            Review[]
  seasonalPrices     SeasonalPrice[]
  pricingRules       PricingRule[]
  icalSyncs          ICalSync[]
  searchEvents       SearchEvent[]

  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  publicId   String
  alt        String?
  category   ImageCategory? @default(OUTRO)
  order      Int      @default(0)
  isCover    Boolean  @default(false)
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

enum ImageCategory {
  SALA
  COZINHA
  QUARTO
  CASA_DE_BANHO
  EXTERIOR
  ENTRADA
  LAVANDARIA
  PISCINA
  JARDIM
  VARANDA
  ESCRITORIO
  OUTRO
}

model Amenity {
  id         String            @id @default(cuid())
  name       String            @unique
  icon       String?
  category   AmenityCategory   @default(GENERAL)
  properties PropertyAmenity[]

  @@map("amenities")
}

model PropertyAmenity {
  propertyId String
  amenityId  String
  amenity    Amenity  @relation(fields: [amenityId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@id([propertyId, amenityId])
  @@map("property_amenities")
}

model Booking {
  id               String        @id @default(cuid())
  propertyId       String
  confirmationCode String        @unique @default(cuid())
  guestName        String
  guestEmail       String
  guestPhone       String?
  guestCount       Int
  checkIn          DateTime
  checkOut         DateTime
  nights           Int
  pricePerNight    Float
  cleaningFee      Float         @default(0)
  securityDeposit  Float         @default(0)
  totalPrice       Float
  currency         String        @default("EUR")
  status           BookingStatus @default(PENDING)
  paymentStatus    PaymentStatus @default(UNPAID)
  paymentIntentId  String?
  guestMessage     String?
  ownerNotes       String?
  source           BookingSource @default(WEBSITE)
  expiresAt        DateTime?
  roomId           String?
  room             Room?         @relation(fields: [roomId], references: [id])
  guestCountry      String?
  acceptedTerms     Boolean   @default(false)
  acceptedPrivacy   Boolean   @default(false)
  acceptedMarketing Boolean   @default(false)
  termsAcceptedAt   DateTime?
  checkedInAt       DateTime?
  checkedOutAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  property         Property      @relation(fields: [propertyId], references: [id])
  review           Review?
  guestAccessLogs  GuestAccess[]
  couponUsage      CouponUsage?
  discountAmount   Float?        @default(0)
  searchEvents     SearchEvent[]

  @@map("bookings")
}

model BlockedDate {
  id         String   @id @default(cuid())
  propertyId String
  date       DateTime @db.Date
  reason     String?
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, date])
  @@map("blocked_dates")
}

model Review {
  id          String   @id @default(cuid())
  propertyId  String
  bookingId   String?  @unique
  guestName   String
  rating      Int
  comment     String?  @db.Text
  ownerReply  String?  @db.Text
  isPublished Boolean  @default(false)
  isRejected  Boolean  @default(false)
  source      String   @default("WEBSITE")
  sourceUrl   String?
  stayDate    DateTime?
  isRejected  Boolean  @default(false)
  stayDate    DateTime?
  source      String?  @default("website")
  sourceUrl   String?
  createdAt   DateTime @default(now())
  booking     Booking? @relation(fields: [bookingId], references: [id])
  property    Property @relation(fields: [propertyId], references: [id])

  @@map("reviews")
}


model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum Role {
  OWNER
  ADMIN
  GUEST
}

enum PropertyType {
  APARTMENT
  HOUSE
  VILLA
  STUDIO
  ROOM
  
}

enum PropertyStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum CancellationPolicy {
  FLEXIBLE
  MODERATE
  STRICT
}

enum AmenityCategory {
  GENERAL
  KITCHEN
  BATHROOM
  BEDROOM
  OUTDOOR
  ENTERTAINMENT
  SAFETY
  ACCESSIBILITY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum BookingSource {
  WEBSITE
  AIRBNB
  BOOKING
  MANUAL
}

enum NotificationType {
  NEW_BOOKING
  BOOKING_CANCELLED
  BOOKING_CONFIRMED
  PAYMENT_RECEIVED
  NEW_REVIEW
  CHECK_IN_REMINDER
  CHECK_OUT_REMINDER
  SYSTEM
}

// ─── ACCESO HUÉSPED ──────────────────────────────────────────────────────────

model GuestAccess {
  id               String   @id @default(cuid())
  email            String
  confirmationCode String?
  bookingId        String
  accessedAt       DateTime @default(now())
  ipAddress        String?

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("guest_access_logs")
}

// ─── CUPONES DE DESCUENTO ─────────────────────────────────────────────────────

model Coupon {
  id              String       @id @default(cuid())
  code            String       @unique
  description     String?
  type            CouponType
  discountValue   Float
  minNights       Int?
  minOrderAmount  Float?
  maxUses         Int?
  currentUses     Int          @default(0)
  isActive        Boolean      @default(true)
  expiresAt       DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  usages          CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id         String   @id @default(cuid())
  couponId   String
  bookingId  String   @unique
  guestEmail String
  discount   Float
  usedAt     DateTime @default(now())

  coupon     Coupon   @relation(fields: [couponId], references: [id])
  booking    Booking  @relation(fields: [bookingId], references: [id])

  @@map("coupon_usages")
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FIRST_BOOKING
  MULTIPLE_USE
}

// ─── HABITACIONES ────────────────────────────────────────────────────────────

model Room {
  id            String     @id @default(cuid())
  propertyId    String
  name          String
  description   String?    @db.Text
  type          RoomType   @default(DOUBLE)
  status        RoomStatus @default(ACTIVE)
  maxGuests     Int        @default(1)
  bedrooms      Int        @default(1)
  bathrooms     Int        @default(1)
  bathroomType  String?    @default("private")
  beds          Int        @default(1)
  bedsList      String?    @db.Text
  services      String?    @db.Text
  pricePerNight Float
  order         Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  seasonalPrices  SeasonalPrice[]
  pricingRules    PricingRule[]
  icalSyncs       ICalSync[]

  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  images       RoomImage[]
  bookings     Booking[]
  blockedDates RoomBlockedDate[]
  searchEvents SearchEvent[]

  @@map("rooms")
}

model RoomImage {
  id        String   @id @default(cuid())
  roomId    String
  url       String
  publicId  String
  alt       String?
  category  ImageCategory? @default(OUTRO)
  order     Int      @default(0)
  isCover   Boolean  @default(false)
  createdAt DateTime @default(now())

  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("room_images")
}

model RoomBlockedDate {
  id     String   @id @default(cuid())
  roomId String
  date   DateTime @db.Date
  reason String?

  room   Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, date])
  @@map("room_blocked_dates")
}

enum RoomType {
  SINGLE
  DOUBLE
  TWIN
  SUITE
  JUNIOR_SUITE
  FAMILY
  STUDIO
  ENTIRE_PLACE
}

enum RoomStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

// ─── PRECIOS DINÁMICOS ───────────────────────────────────────────────────────

model SeasonalPrice {
  id            String    @id @default(cuid())
  propertyId    String
  roomId        String?
  name          String
  startDate     DateTime  @db.Date
  endDate       DateTime  @db.Date
  pricePerNight Float
  minNights     Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  property      Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room          Room?     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("seasonal_prices")
}

model PricingRule {
  id            String      @id @default(cuid())
  propertyId    String
  roomId        String?
  type          PricingRuleType
  value         Float
  isPercentage  Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  property      Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room          Room?       @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("pricing_rules")
}

enum PricingRuleType {
  WEEKEND_MARKUP
  LONG_STAY_DISCOUNT
  MINIMUM_PRICE
}

// ─── ICAL SYNC ────────────────────────────────────────────────────────────────

model ICalSync {
  id           String    @id @default(cuid())
  propertyId   String
  roomId       String?
  source       String
  icalUrl      String
  lastSyncedAt DateTime?
  syncedDates  Int       @default(0)
  createdAt    DateTime  @default(now())

  property     Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room         Room?     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("ical_syncs")
}

// ─── SEARCH EVENT TRACKING ────────────────────────────────────────────────────

model SearchEvent {
  id                 String    @id @default(cuid())
  propertyId         String?
  roomId             String?
  checkIn            DateTime?
  checkOut           DateTime?
  guests             Int?
  sessionId          String
  ipAddress          String?
  convertedToBooking Boolean   @default(false)
  bookingId          String?
  createdAt          DateTime  @default(now())

  property  Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  room      Room?     @relation(fields: [roomId], references: [id], onDelete: SetNull)
  booking   Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([propertyId])
  @@index([createdAt])
  @@map("search_events")
}
// ─── WEB PUSH ─────────────────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}
